{
  "collections": {
    "users": {
      "schema": {
        "uid": { "type": "string", "required": true },
        "name": { "type": "string", "required": true },
        "email": { "type": "string", "required": true },
        "createdAt": { "type": "string", "required": true }
      }
    },
    "users/{userId}/jobs": {
      "schema": {
        "id": { "type": "string", "required": true },
        "title": { "type": "string", "required": true },
        "company": { "type": "string", "required": true },
        "department": { "type": "string", "required": true },
        "location": { "type": "string", "required": true },
        "type": { "type": "string", "required": true },
        "salaryRange": { "type": "string", "required": false },
        "experienceRequired": { "type": "string", "required": true },
        "educationRequired": { "type": "string", "required": true },
        "mandatorySkills": { "type": "string", "required": true },
        "preferredSkills": { "type": "string", "required": false },
        "description": { "type": "string", "required": true },
        "responsibilities": { "type": "string", "required": false },
        "benefits": { "type": "string", "required": false },
        "createdAt": { "type": "string", "required": true },
        "endDate": { "type": "string", "required": false },
        "analyzedRequirements": { "type": "map", "required": false }
      }
    },
    "users/{userId}/candidates": {
      "schema": {
        "id": { "type": "string", "required": true },
        "jobId": { "type": "string", "required": true },
        "name": { "type": "string", "required": true },
        "email": { "type": "string", "required": true },
        "phone": { "type": "string", "required": true },
        "resumeText": { "type": "string", "required": true },
        "matchScore": { "type": "number", "required": true },
        "eligibilityStatus": { "type": "string", "required": true },
        "notes": { "type": "string", "required": false },
        "evaluatedAt": { "type": "string", "required": false },
        "appliedAt": { "type": "string", "required": false },
        "resultsAvailableAt": { "type": "string", "required": false },
        "report": { "type": "map", "required": false }
      }
    },
    "notifications": {
      "schema": {
        "id": { "type": "string", "required": true },
        "userId": { "type": "string", "required": true },
        "title": { "type": "string", "required": true },
        "message": { "type": "string", "required": true },
        "type": { "type": "string", "required": true },
        "createdAt": { "type": "string", "required": true },
        "isRead": { "type": "boolean", "required": true },
        "jobId": { "type": "string", "required": false },
        "candidateId": { "type": "string", "required": false }
      }
    }
  }
}
